{
    "name": "datalogix/laravel-guardian",
    "description": "Extensible Laravel authentication package providing actions for login, logout, sign-up, password reset, email verification and related security features.",
    "keywords": [
        "laravel",
        "authentication",
        "login",
        "logout",
        "signup",
        "password-reset",
        "email-verification",
        "security",
        "rate-limiting",
        "guard"
    ],
    "homepage": "https://github.com/datalogix/laravel-guardian",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ricardo Gobbo de Souza",
            "email": "ricardogobbosouza@yahoo.com.br"
        }
    ],
    "require": {
        "php": "^8.2",
        "bacon/bacon-qr-code": "^3.0",
        "illuminate/auth": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/session": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/validation": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "pragmarx/google2fa": "^8.0"
    },
    "require-dev": {
        "graham-campbell/testbench": "^6.2",
         "laravel/pint": "^1.27",
        "livewire/livewire": "^3.6|^4.2"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "Datalogix\\Guardian\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Datalogix\\Guardian\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/pint",
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Datalogix\\Guardian\\GuardianServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
